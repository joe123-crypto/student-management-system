{
  "name": "scholarsalger---foreign-student-management-system",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prisma:generate": "node scripts/prisma-generate-safe.mjs",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "node scripts/prisma-generate-safe.mjs",
    "predev": "node scripts/prisma-generate-safe.mjs",
    "prebuild": "node scripts/prisma-generate-safe.mjs",
    "dev": "node scripts/next-with-canonical-cwd.mjs dev",
    "build": "node scripts/next-with-canonical-cwd.mjs build",
    "start": "node scripts/next-with-canonical-cwd.mjs start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:check": "node scripts/check-frontend-data-model-docs.mjs",
    "test:auth": "node --import tsx --test test/auth/**/*.test.ts",
    "test:storage": "node --import tsx --test test/storage/**/*.test.ts",
    "typecheck:auth": "tsc -p tsconfig.auth-tests.json",
    "typecheck": "tsc --noEmit",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.2",
    "lucide-react": "^0.575.0",
    "next": "15.5.14",
    "next-auth": "^4.24.13",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "overrides": {
    "@prisma/config": {
      "effect": "3.21.0"
    }
  }
}
