generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ATTACHE
}

enum AuthProvider {
  student_inscription
  attache_email
}

enum StudentProfileStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model AuthUser {
  id                String       @id @default(cuid())
  role              UserRole
  loginId           String
  subject           String
  authProvider      AuthProvider
  passwordHash      String
  isActive          Boolean      @default(true)
  failedSignInCount Int          @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  auditLogs         AuditLog[]
  studentProfile    StudentProfileRecord?

  @@unique([role, loginId])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?
  event     String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  user      AuthUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model StudentProfileRecord {
  id                String               @id
  authUserId        String?              @unique
  inscriptionNumber String               @unique
  fullName          String
  status            StudentProfileStatus @default(PENDING)
  profile           Json
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  authUser          AuthUser?            @relation(fields: [authUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([fullName])
}
